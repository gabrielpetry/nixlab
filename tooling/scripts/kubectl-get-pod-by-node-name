#!/usr/bin/env bash

set -o pipefail

# Self-contained wrapper: prefer kubecolor with forced colors, fall back to kubectl
_kubecmd() {
    if command -v kubecolor >/dev/null 2>&1; then
        kubecolor --force-colors "$@"
    else
        kubectl "$@"
    fi
}

# Shows pods on a given node with resource usage (combining get pod + top pod)
kubectl-get-pod-by-node-name() {
    local node_name="$1"
    [[ -z "$node_name" ]] && {
        echo "Usage: $0 <node-name>" >&2
        exit 1
    }

    local get_temp_file top_temp_file top_final_temp_file
    local get_output top_output
    local columns="NAMESPACE,NAME,CPU,MEMORY,READY,STATUS,RESTARTS,AGE"

    get_temp_file="$(mktemp)"
    top_temp_file="$(mktemp)"
    top_final_temp_file="$(mktemp)"

    {
        _kubecmd get pods --no-headers --all-namespaces --field-selector "spec.nodeName=$node_name" \
            | sed -E 's/([0-9]+) \((\S+) ago\)/\1_(\2_ago)/g' >"$get_temp_file" &
        _kubecmd top pods --no-headers --all-namespaces >"$top_temp_file" &
    } >/dev/null 2>&1

    wait 2>/dev/null

    while read -r line; do
        pod_name="$(echo "$line" | clear-ansi | awk '{print $2}')"
        if grep -q "$pod_name" "$get_temp_file"; then
            echo "$line" >>"$top_final_temp_file"
        fi
    done < <(cat "$top_temp_file")

    get_output="$(cat "$get_temp_file" | sort | awk '{print $1"|"$2, $3, $4, $5, $6, $7, $8}')"
    top_output="$(cat "$top_final_temp_file" | sort | awk '{print $1"|"$2, $3, $4, $5, $6, $7, $8}')"

    rm "$get_temp_file" "$top_temp_file" "$top_final_temp_file"

    if [[ -t 1 ]]; then
        join <(echo -e "$top_output") <(echo -e "$get_output") |
            sed 's/|/\t/g' |
            column --table --table-columns="$columns" |
            sed -E 's/([0-9]+)_\((\S+)_ago\)/\1 (\2 ago)/g'
    else
        join <(echo -e "$top_output") <(echo -e "$get_output") |
            sed 's/|/\t/g' |
            column --table --table-columns="$columns" |
            sed -E 's/([0-9]+)_\((\S+)_ago\)/\1 (\2 ago)/g' |
            clear-ansi
    fi
}

main() {
    kubectl-get-pod-by-node-name "$@"
}

main "$@"
